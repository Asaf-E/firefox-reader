{
  "manifest_version": 3,
  "name": "Novel Reader",
  "version": "0.1.6",
  "description": "Reader-focused extension for extracting, rewriting, and continuing web novel chapters.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "48": "icons/firefox-reader.svg",
    "96": "icons/firefox-reader.svg"
  },
  "action": {
    "default_title": "Open Novel Reader",
    "default_icon": {
      "48": "icons/firefox-reader.svg",
      "96": "icons/firefox-reader.svg"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "firefox-reader@asax.local",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "websiteActivity"
        ]
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
